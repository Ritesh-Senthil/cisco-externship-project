# Copy to .env.hosted (gitignored via .env*) and fill in after cloud deploy.
# Used by ./scripts/wire_splunk.sh on any machine that runs local Docker Splunk.

# Public Northflank (or local) backend — no trailing slash
EVENTSHIELD_API_BASE=https://YOUR-BACKEND.northflank.app

# Must match DEMO_ADMIN_TOKEN on the hosted backend (required for attach/detach)
DEMO_ADMIN_TOKEN=change-me-to-a-long-random-secret

# Same default HEC token as docker-compose / splunk/default.yml / .env.example
SPLUNK_HEC_TOKEN=eventshield-hec-token-change-me
