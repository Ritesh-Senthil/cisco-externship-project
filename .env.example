# EventShield environment
# Copy to .env and adjust as needed.

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DATABASE_URL=postgresql+asyncpg://eventshield:eventshield@localhost:5432/eventshield
REDIS_URL=redis://localhost:6379/0
# Best-effort Postgres persistence + Redis snapshot fanout. Safe to leave on:
# if the containers are down the backend degrades gracefully and stays in-memory.
PERSISTENCE_ENABLED=true
# Comma-separated. Add your Vercel URL when hosting the UI.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# LLM — set provider to "openai" or "ollama"
# qwen2.5:7b-instruct is the recommended local model (best quality/speed on ~16GB+
# Apple Silicon). Use llama3.2 (3B) on lower-RAM machines for faster/lighter answers.
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:7b-instruct
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OLLAMA_BASE_URL=http://localhost:11434
# 18s covers a 7B cold load (~15s); warm answers return in ~4-5s.
LLM_TIMEOUT_SECONDS=18
AI_FALLBACK_DEFAULT=true

# Splunk HEC (local Docker defaults — keep token in sync with docker-compose + splunk/default.yml)
SPLUNK_HEC_URL=https://localhost:8088/services/collector
SPLUNK_HEC_TOKEN=eventshield-hec-token-change-me
SPLUNK_HEC_VERIFY_SSL=false
SPLUNK_ENABLED=true

# Cisco Catalyst Center (real control-plane evidence, read-only, best-effort).
# OFF by default so local/offline demos never call out. Hosted sets CATALYST_LIVE=true
# to light up the "Connected · N devices" provenance badge in the Evidence drawer.
CATALYST_LIVE=false
CATALYST_BASE_URL=https://sandboxdnac.cisco.com
CATALYST_USERNAME=devnetuser
CATALYST_PASSWORD=Cisco123!
CATALYST_VERIFY_SSL=false
CATALYST_POLL_SECONDS=30
CATALYST_TIMEOUT_SECONDS=6

# Protects /api/admin/splunk/attach|detach. Leave empty for open local demo.
# Hosted (Northflank) MUST set a non-empty secret; laptop wire_splunk.sh sends it.
DEMO_ADMIN_TOKEN=

# Demo
DEMO_SEED=42

